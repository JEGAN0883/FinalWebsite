{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/features", "dest": "/features.html" },
    { "src": "/how-it-works", "dest": "/how-it-works.html" },
    { "src": "/pricing", "dest": "/pricing.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/early-access", "dest": "/early-access.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
